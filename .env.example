# Keystatic admin (optional — leave unset for local file editing in development)
#
# Production editing on Vercel requires GitHub mode:
# 1. Set NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO to "owner/repo"
# 2. Visit /keystatic once and create/connect the GitHub App
# 3. Copy the generated values into Vercel env vars
#
# NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO=your-github-username/portfolio
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
