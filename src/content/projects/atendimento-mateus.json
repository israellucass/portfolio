                  "kind": "paragraph",
                  "align": "left",
                  "inlines": [
                    {
                      "text": "1.",
                      "marks": [
                        "bold"
                      ],
                      "color": "#ffc239"
                    },
                    {
                      "text": " Features combined",
                      "marks": [
                        "bold"
                      ]
                    },
                    {
                      "text": "\n"
                    }
                  ]
                },
                {
                  "kind": "paragraph",
                  "align": "left",
                  "inlines": [
                    {
                      "text": "The app now includes a dedicated section for retail information, featuring store indicators (in red), as well as a section for accessing standard operating procedures (in yellow).",
                      "color": "#f0f3f5"
                    },
                    {
                      "text": "\n"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
