                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "tree",
      "columns": [
        {
          "flex": 13,
          "blocks": [
            {
              "type": "image",
              "src": "/images/assets/a5aafc23-024f-4c17-8eda-e4a1530c088a_rw_600.gif",
              "lightboxSrc": "/images/assets/a5aafc23-024f-4c17-8eda-e4a1530c088a.gif"
            }
          ]
        },
        {
          "flex": 27,
          "blocks": [
            {
              "type": "richtext",
              "paragraphs": [
                {
                  "kind": "paragraph",
                  "inlines": [
                    {
                      "text": "3.",
                      "marks": [
                        "bold"
                      ],
                      "color": "#ffc239"
                    },
                    {
                      "text": " Information on procedures",
                      "marks": [
