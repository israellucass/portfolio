              "lightboxSrc": "/images/assets/25f3a264-61de-49ae-9b61-722224e7d9c1.png"
            }
          ]
        }
      ]
    },
    {
      "type": "richtext",
      "paragraphs": [
        {
          "kind": "paragraph",
          "inlines": [
            {
              "text": "In the end, a flowchart with game screens and inputs was designed to guide the development team on the game navigation on the Unity engine.\n"
            }
          ]
        }
      ]
    },
