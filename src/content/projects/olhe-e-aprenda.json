              "text": "VALIDATION AND TESTING",
              "color": "#ffa92f"
            },
            {
              "text": "\n"
            }
          ]
        },
        {
          "kind": "paragraph",
          "inlines": [
            {
              "text": "To validate the initial version, a ",
              "color": "#f0f3f5"
            },
            {
              "text": "usability evaluation",
              "marks": [
                "bold"
              ],
              "color": "#f0f3f5"
            },
            {
              "text": ", comprising ",
              "color": "#f0f3f5"
            },
            {
              "text": "heuristic evaluation",
              "color": "#ffa92f"
            },
            {
              "text": ", ",
              "color": "#f0f3f5"
            },
            {
              "text": "usability testing",
              "color": "#ffa92f"
            },
            {
              "text": " and a ",
              "color": "#f0f3f5"
            },
            {
              "text": "group-based expert walkthrough",
              "color": "#ffa92f"
            },
            {
              "text": ", was conducted as part of my Master's thesis. Since it contains unpublished data, the ",
              "color": "#f0f3f5"
            },
            {
              "text": "full process will be added to this section once the publication is released.\n \n"
            }
          ]
        }
      ]
    }
  ]
